{
  "name": "@beefyfinance/cowllector",
  "version": "2.0.0",
  "description": "The bot to harvest all vaults.",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "node ./node_modules/typescript/lib/tsc.js",
    "dev": "tsx ./src/script/harvest.ts",
    "heroku:harvest": "node ./dist/script/harvest.js -c all",
    "heroku:unwrap": "node ./dist/script/unwrap.js -c all",
    "heroku:revenue": "node ./dist/script/revenue-bridge-harvest.js -c all",
    "heroku:db:migrate": "node ./dist/script/db/migrate.js",
    "heroku:db:apply-retention": "node ./dist/script/db/apply-retention.js",
    "db:migrate": "tsx ./src/script/db/migrate.ts",
    "db:apply-retention": "tsx ./src/script/db/apply-retention.ts",
    "format": "biome check --write --unsafe",
    "format:safe": "biome check --write",
    "test:lint": "biome ci",
    "test:ts": "node ./node_modules/typescript/lib/tsc.js --noEmit",
    "test:unit": "DATABASE_URL=ok LOG_LEVEL=error TZ=UTC jest --maxConcurrency=1",
    "test:unused-exports": "knip",
    "test": "pnpm test:lint && pnpm test:ts && pnpm test:unit && pnpm test:unused-exports",
    "update:addressbook": "pnpm up @beefyfinance/blockchain-addressbook viem"
  },
  "dependencies": {
    "@beefyfinance/blockchain-addressbook": "0.56.1",
    "async-lock": "1.4.1",
    "axios": "catalog:",
    "dotenv": "catalog:",
    "lodash": "4.18.1",
    "pg": "catalog:",
    "pg-connection-string": "catalog:",
    "pg-format": "1.0.4",
    "pino": "catalog:",
    "table": "6.9.0",
    "viem": "catalog:",
    "yaml": "2.9.0",
    "yargs": "18.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@swc/core": "1.15.43",
    "@swc/jest": "0.2.39",
    "@types/async-lock": "1.4.2",
    "@types/jest": "30.0.0",
    "@types/lodash": "4.17.24",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "@types/pg-format": "1.0.5",
    "jest": "30.4.2",
    "knip": "6.20.0",
    "pino-pretty": "13.1.3",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
