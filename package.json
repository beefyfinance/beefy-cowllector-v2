{
  "name": "@beefyfinance/cowllector-monorepo",
  "version": "2.0.0",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": "26.x",
    "pnpm": "11.x"
  },
  "scripts": {
    "build": "if [ -n \"$STACK\" ]; then pnpm run build:heroku; else turbo run build; fi",
    "build:heroku": "pnpm --filter @beefyfinance/cowllector build",
    "dev": "turbo run dev",
    "dev:cowllector": "turbo run dev --filter=@beefyfinance/cowllector",
    "dev:api": "turbo run dev --filter=@beefyfinance/cowllector-api",
    "format": "turbo format",
    "format:safe": "turbo format:safe",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:lint": "turbo run test:lint",
    "test:ts": "turbo run test:ts",
    "test:unused-exports": "turbo run test:unused-exports",
    "precommit": "lefthook run pre-commit",
    "infra:start": "docker compose -p dev -f docker-compose.dev.yml up -d",
    "infra:logs": "docker compose -p dev -f docker-compose.dev.yml logs -f",
    "infra:stop": "docker compose -p dev -f docker-compose.dev.yml down",
    "pg:console": "docker exec -it dev-postgres-1 psql -U beefy_cowllector",
    "db:migrate": "pnpm --filter @beefyfinance/cowllector db:migrate",
    "update:addressbook": "pnpm --filter @beefyfinance/cowllector update:addressbook",
    "heroku:harvest": "pnpm --filter @beefyfinance/cowllector heroku:harvest",
    "heroku:unwrap": "pnpm --filter @beefyfinance/cowllector heroku:unwrap",
    "heroku:revenue": "pnpm --filter @beefyfinance/cowllector heroku:revenue",
    "heroku:db:migrate": "pnpm --filter @beefyfinance/cowllector heroku:db:migrate",
    "heroku:db:apply-retention": "pnpm --filter @beefyfinance/cowllector heroku:db:apply-retention",
    "prepare": "if [ -z \"$DYNO\" ]; then command -v lefthook >/dev/null && lefthook install || true; fi"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "lefthook": "2.0.12",
    "turbo": "2.8.0",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@11.13.0"
}
